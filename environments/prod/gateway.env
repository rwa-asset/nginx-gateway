APP_ENV=prod
GATEWAY_CONTAINER_NAME=rwagate-nginx
EDGE_NETWORK_NAME=rwat-edge
WITTGENS_WEB_ROOT=/var/www/wittgens
WITTGENS_WEB_ENV=prod

RWAT_FRONTEND_DOMAINS="wittgens.ai www.wittgens.ai"
RWAT_API_DOMAIN=api.wittgens.ai 
RWAT_ADMIN_DOMAIN=admin.wittgens.ai
RWAT_ALL_DOMAINS="${RWAT_FRONTEND_DOMAINS} ${RWAT_API_DOMAIN} ${RWAT_ADMIN_DOMAIN}"
RWAT_FRONTEND_ROOT=/var/www/wittgens/${WITTGENS_WEB_ENV}
RWAT_API_UPSTREAM=http://rwat-go-server:8000
RWAT_ADMIN_UPSTREAM=http://rwat-admin-ui:80

RWAT_CERT_NAME=wittgens.ai
RWAT_CERT_DOMAINS="${RWAT_ALL_DOMAINS}"
CERT_GROUP_KEYS="RWAT_CERT"
